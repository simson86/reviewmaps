{
  "permissions": {
    "allow": [
      "Bash(git --version)",
      "Bash(gh --version)",
      "Bash(git config *)",
      "Bash(echo \"user.name: $\\(git config --global user.name\\)\")",
      "Bash(echo \"user.email: $\\(git config --global user.email\\)\")",
      "Bash(echo \"default branch: $\\(git config --global init.defaultBranch\\)\")",
      "PowerShell(Get-Command *)"
    ]
  }
}
